# SmartTest 智能化测试平台环境配置

# ===========================================
# Django基础配置
# ===========================================
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# 数据库配置 (MySQL)
# ===========================================
DB_NAME=smarttest
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# ===========================================
# Redis配置
# ===========================================
REDIS_URL=redis://localhost:6379/1

# ===========================================
# Celery配置
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# 飞书机器人配置
# ===========================================
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ===========================================
# 大模型API配置
# ===========================================
# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini
GOOGLE_API_KEY=xxxxxxxxxxxxxxxx

# 百度文心一言
BAIDU_API_KEY=xxxxxxxx
BAIDU_SECRET_KEY=xxxxxxxx

# 阿里通义千问
DASHSCOPE_API_KEY=sk-xxxxxxxx

# 讯飞星火
XUNFEI_APP_ID=xxxxxxxx
XUNFEI_API_KEY=xxxxxxxx
XUNFEI_API_SECRET=xxxxxxxx

# 智谱AI
ZHIPU_API_KEY=xxxxxxxx.xxxxxxxx

# 月之暗面Kimi
MOONSHOT_API_KEY=sk-xxxxxxxx
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# MiniMax
MINIMAX_API_KEY=xxxxxxxx
MINIMAX_GROUP_ID=xxxxxxxx

